# SandPanel Environment Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── Panel Ports ──────────────────────────────────────────────
# Frontend web UI port
FRONTEND_PORT=22369

# Backend API port (internal, used by frontend)
BACKEND_PORT=8080

# ── Game Server Ports ────────────────────────────────────────
GAME_PORT=27102
QUERY_PORT=27131
RCON_PORT=27015

# ── RCON ─────────────────────────────────────────────────────
# RCON password for game server communication
RCON_PASSWORD=change-me-rcon-password

# ── Game Server Install Path ─────────────────────────────────
# Path to Insurgency: Sandstorm dedicated server installation
# Use ./sandstorm-install if installed locally, or an absolute path
SANDSTORM_INSTALL_PATH=./sandstorm-install

# ── User/Group IDs ───────────────────────────────────────────
PUID=1000
PGID=1000
